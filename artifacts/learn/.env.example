# Frontend — local development environment
# Copy this file:  cp artifacts/learn/.env.example artifacts/learn/.env

# ── Clerk Auth ───────────────────────────────────────────────────────────────
# Must match CLERK_PUBLISHABLE_KEY in artifacts/api-server/.env
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── API URL ───────────────────────────────────────────────────────────────────
# Points the frontend at your local API server
VITE_API_URL=http://localhost:8080

# Clerk proxy URL — routes Clerk auth requests through your local API server
VITE_CLERK_PROXY_URL=http://localhost:8080/api/__clerk

# ── Dev Server ────────────────────────────────────────────────────────────────
# Port for the Vite dev server (default: 3000)
PORT=3000

# Base path — always / for local development
BASE_PATH=/

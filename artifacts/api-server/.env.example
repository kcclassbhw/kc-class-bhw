# API Server — local development environment
# Copy this file:
#   Windows:  copy artifacts\api-server\.env.example artifacts\api-server\.env
#   Mac/Linux: cp artifacts/api-server/.env.example artifacts/api-server/.env

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — local PostgreSQL:
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/learnhub
# Option B — Neon (free cloud, no install needed):
#   Sign up at https://neon.tech → create a project → copy the connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/learnhub

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from your Clerk dashboard at https://dashboard.clerk.com
# Must match VITE_CLERK_PUBLISHABLE_KEY in artifacts/learn/.env
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# ── eSewa Payments (optional — sandbox works without these) ───────────────────
# Leave blank to use eSewa sandbox (test mode). Only needed for live payments.
# ESEWA_PRODUCT_CODE=YOUR_MERCHANT_CODE
# ESEWA_SECRET_KEY=YOUR_SECRET_KEY
# ESEWA_MONTHLY_PRICE=299
# ESEWA_YEARLY_PRICE=2399
# ESEWA_ENV=production
